# ============================================
# Robot PMS 环境变量配置模板
# ============================================
# 说明：
# 1. 复制此文件为 .env（命令：cp .env.example .env）
# 2. 填写您的真实密钥和配置信息
# 3. 确保 .env 文件不会被提交到 Git 仓库（已在 .gitignore 中配置）
# ============================================

# ============ 服务配置 ============
# 服务运行端口（默认 5000）
PORT=5000
# 部署运行端口（云环境使用）
DEPLOY_RUN_PORT=5000
# 项目域名（用于生成回调URL等）
COZE_PROJECT_DOMAIN_DEFAULT=https://your-domain.example.com

# ============ JWT 安全配置 ============
# JWT 密钥（必须修改为随机字符串，建议32位以上）
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-jwt-secret-change-me-in-production

# ============ 科大讯飞星火大模型配置 ============
# 科大讯飞开放平台：https://www.xfyun.cn/
# 获取方式：控制台 -> 我的应用 -> 创建应用 -> 获取密钥

# 星火大模型 API Key
XUNFEI_LLM_API_KEY=your-xunfei-llm-api-key

# 星火大模型 API Secret
XUNFEI_LLM_API_SECRET=your-xunfei-llm-api-secret

# 星火大模型 App ID
XUNFEI_LLM_APP_ID=your-xunfei-llm-app-id

# 星火大模型 API 地址（根据模型版本选择）
XUNFEI_LLM_API_URL=https://spark-api-open.xf-yun.com/v1/chat/completions

# ============ 科大讯飞 RAG 知识库配置 ============
# RAG API Key（如果与LLM使用同一应用，可填写相同值）
XUNFEI_RAG_API_KEY=your-xunfei-rag-api-key

# RAG API Secret
XUNFEI_RAG_API_SECRET=your-xunfei-rag-api-secret

# RAG App ID
XUNFEI_RAG_APP_ID=your-xunfei-rag-app-id

# RAG API 地址
XUNFEI_RAG_API_URL=https://rag-api-open.xf-yun.com/v1/rag

# ============ Coze AI 配置 ============
# Coze API Token（如使用 Coze 平台）
COZE_API_TOKEN=your-coze-api-token

# Coze Bot ID
COZE_BOT_ID=your-coze-bot-id

# ============ 对象存储配置（S3 兼容）============
# 存储服务端点
STORAGE_ENDPOINT=https://your-storage-endpoint.com

# 存储桶名称
STORAGE_BUCKET=your-bucket-name

# 访问密钥 ID
STORAGE_ACCESS_KEY_ID=your-access-key-id

# 访问密钥 Secret
STORAGE_ACCESS_KEY_SECRET=your-access-key-secret

# 访问区域
STORAGE_REGION=auto

# ============ 邮件服务配置（可选）============
# SMTP 服务器地址
SMTP_HOST=smtp.example.com

# SMTP 端口（通常 465 或 587）
SMTP_PORT=587

# SMTP 用户名（邮箱地址）
SMTP_USER=your-email@example.com

# SMTP 密码或授权码
SMTP_PASS=your-smtp-password-or-auth-code

# 发件人邮箱
SMTP_FROM_EMAIL=noreply@example.com

# 发件人名称
SMTP_FROM_NAME=Robot PMS

# ============ 数据库配置 ============
# 数据库文件路径（默认 server/data/robot_pms.db）
DATABASE_PATH=./server/data/robot_pms.db

# ============ 日志配置 ============
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# ============ 开发环境标识 ============
# 环境：DEV 或 PROD
COZE_PROJECT_ENV=DEV
