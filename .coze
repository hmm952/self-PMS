[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "-c", "cd client && pnpm install && pnpm run build && cd ../server && pnpm install"]
run = ["node", "server/src/index.js"]

[deploy]
build = ["bash", "-c", "cd client && pnpm install && pnpm run build && cd ../server && pnpm install"]
run = ["node", "server/src/index.js"]
